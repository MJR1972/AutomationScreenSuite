<Window x:Class="AutomationScreenStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AutomationScreenStudio.Controls"
        mc:Ignorable="d"
        Title="Automation Screen Studio"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#FFF2EEE6">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFE7D8C7" BorderBrush="#FFC4B29B" BorderThickness="0,0,0,1" Padding="12">
            <ToolBarTray Background="Transparent">
                <ToolBar Background="Transparent" BorderThickness="0">
                    <Button Command="{Binding CaptureRegionCommand}" Content="Capture Region" Padding="12,6" Margin="0,0,8,0" />
                    <Button Command="{Binding SaveImageCommand}" Content="Save" Padding="12,6" Margin="0,0,8,0" />
                    <Button Command="{Binding ClearMarkupsCommand}" Content="Clear Markups" Padding="12,6" Margin="0,0,8,0" />
                    <Button Command="{Binding DeleteSelectedCommand}" Content="Delete Selected" Padding="12,6" Margin="0,0,16,0" />
                    <Separator />
                    <TextBlock VerticalAlignment="Center" Margin="12,0,8,0" Text="Tool" FontWeight="SemiBold" />
                    <ComboBox Width="160"
                              ItemsSource="{Binding ToolModes}"
                              SelectedItem="{Binding SelectedTool}"
                              Margin="0,0,16,0" />
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Color" FontWeight="SemiBold" />
                    <ComboBox Width="160"
                              ItemsSource="{Binding AvailableColors}"
                              SelectedItem="{Binding SelectedColorOption}"
                              DisplayMemberPath="Name"
                              Margin="0,0,16,0" />
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Thickness" FontWeight="SemiBold" />
                    <Slider Width="140"
                            Minimum="1"
                            Maximum="20"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding SelectedThickness}" />
                </ToolBar>
            </ToolBarTray>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#FFDED6CA" BorderBrush="#FFC4B29B" BorderThickness="0,1,0,0" Padding="12,8">
            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />
        </Border>

        <Grid Margin="12">
            <controls:EditorControl x:Name="Editor"
                                    CapturedImage="{Binding CapturedImage}"
                                    SelectedColor="{Binding SelectedColor}"
                                    SelectedThickness="{Binding SelectedThickness}"
                                    SelectedTool="{Binding SelectedTool}" />
        </Grid>
    </DockPanel>
</Window>
